{
  "$schema": "https://schema.tauri.app/v2/config.json",
  "productName": "Allurite",
  "version": "1.0.0",
  "identifier": "com.allurite.crm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://allurite.vercel.app"
  },
  "app": {
    "windows": [
      {
        "title": "Allurite CRM",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "maximized": false,
        "center": true,
        "focus": true,
        "visible": true,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Allurite",
    "copyright": "Copyright © 2026 Allurite",
    "category": "Business",
    "shortDescription": "Allurite CRM Desktop Application",
    "longDescription": "Professional native Windows Desktop Application for Allurite CRM."
  }
}
